# ThinkTwice — local environment template.
# Copy this file to `.env.local` (which is gitignored) and fill in the value.
#
# OPENROUTER_API_KEY
#   Your OpenRouter API key. Get one at https://openrouter.ai/keys
#   Required when using OpenRouter backend (default).
#
# CLAUDE_CODE_OAUTH_TOKEN
#   Optional — set this INSTEAD of OPENROUTER_API_KEY to use the Claude CLI
#   backend. Generate with:  claude setup-token
#   Only one backend key is needed.
OPENROUTER_API_KEY=
